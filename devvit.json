{
  "$schema": "https://developers.reddit.com/schema/config-file.v1.json",
  "name": "splash-siege",
  "post": {
    "dir": "dist/client",
    "entrypoints": {
      "default": {
        "entry": "index.html",
        "height": "tall"
      }
    }
  },
  "server": {
    "dir": "dist/server",
    "entry": "index.cjs"
  },
  "media": {
    "dir": "assets"
  },
  "menu": {
    "items": [
      {
        "label": "Create Splash Siege post",
        "description": "Creates a new Splash Siege game post",
        "location": "subreddit",
        "forUserType": "moderator",
        "endpoint": "/internal/menu/post-create"
      }
    ]
  },
  "triggers": {
    "onAppInstall": "/internal/on-app-install"
  },
  "dev": {
    "subreddit": "splash_siege_dev"
  },
  "marketingAssets": {
    "icon": "assets/icon.png"
  }
}